# MGM Secure Guest System — Environment Configuration
# Copy this file to .env and fill in real values before running.

# Flask session signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

MONGO_URI=mongodb://localhost:27017/

# Encryption-at-rest key for the sensitive guest collection (Fernet). Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DATA_ENCRYPTION_KEY=change-me

# Set to "true" only when served over HTTPS (marks the session cookie Secure).
COOKIE_SECURE=false

# Idle session timeout in minutes before auto-logout.
SESSION_TIMEOUT_MINUTES=30

# Default seed credentials (used ONLY on first run to create accounts).
# Users are forced to change these on first login.
ADMIN_DEFAULT_PASSWORD=Admin@12345
STAFF_DEFAULT_PASSWORD=Staff@12345
SECURITY_DEFAULT_PASSWORD=Security@12345
